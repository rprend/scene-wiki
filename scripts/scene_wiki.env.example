# Copy to .scene-wiki.env or point SCENE_WIKI_CONFIG at your own file.

RUN_DIR=/absolute/path/to/data/runs/<run-id>
VAULT_DIR=/absolute/path/to/vault/<dataset-slug>
WIKI_DIR=/absolute/path/to/wiki
OUTPUT_DIR=/absolute/path/to/dist/wiki
CACHE_DIR=/absolute/path/to/.cache/scene-wiki

WIKI_CORPUS_FILENAME=corpus.json
SCENE_WIKI_TITLE="Example Wiki"
SCENE_WIKI_ARCHIVE_LABEL="Example Publication"
QUARTZ_PAGE_TITLE="Example Wiki"
QUARTZ_BASE_URL=<your-pages-project>.pages.dev
PROJECT_NAME=<cloudflare-pages-project-name>
