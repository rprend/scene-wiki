# Cloudflare Worker app
PLATFORM_BASE_URL=https://scene-wiki-platform.<your-subdomain>.workers.dev
RUNNER_API_TOKEN=replace-with-long-random-token
MAIN_DOMAIN=scene.yourdomain.com
PAGES_PROJECT_PREFIX=scene-wiki

# Cloudflare deploy/auth
CLOUDFLARE_ACCOUNT_ID=replace-with-account-id
CLOUDFLARE_API_TOKEN=replace-with-api-token

# Scene wiki generation
GOOGLE_API_KEY=
GEMINI_API_KEY=
SUBSTACK_COOKIE=

# Runner behavior
RUNNER_POLL_SECONDS=20
RUNNER_WORKDIR=/absolute/path/to/scene-wiki
